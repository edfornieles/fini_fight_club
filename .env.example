# ── Supabase (backend) ──────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Optional: override the functions URL if you proxy them
# Default = ${VITE_SUPABASE_URL}/functions/v1
# VITE_SUPABASE_FUNCTIONS_URL=https://your-project.functions.supabase.co

# ── WalletConnect ───────────────────────────────────────────────────────────
# Free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=demo

# ── Ownership snapshot ──────────────────────────────────────────────────────
# Path/URL the SnapshotOwnershipProvider fetches. Defaults to /data/ownership.json
# served from public/. Set this if you host the snapshot externally.
# VITE_SNAPSHOT_URL=https://snapshots.fini.xyz/ownership.json

# ── Server-only env (set in Supabase Edge Functions secrets, NOT here) ──────
# These never reach the client. Reference only.
# SUPABASE_URL=...                  (auto-set by Supabase)
# SUPABASE_SERVICE_ROLE_KEY=...     (set in Edge Functions secrets)
# SIWE_DOMAIN=fini.xyz              (the domain users sign for)
# INTERNAL_API_KEY=...              (required for credit-balance endpoint)
